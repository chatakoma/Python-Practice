#Now let's explore Databases
#@SQLite example

import sqlite3

conn = sqlite3.connect("database.db")
cur = conn.cursor()

cur.execute("CREATE TABLE IF NOT EXISTS users(id INT, name TEXT)")
cur.execute("INSERT INTO users VALUES(1, 'Aicha')")

conn.commit()
conn.close()


