#Machine Learning Introduction(With scikit-learn)
#First install : pip install scikit-learn

from sklearn.linear_model import LinearRegression
import numpy as np

x = np.array([[1], [2], [3]])
y = np.array([2, 4, 6])

model = LinearRegression()
model.fit(x, y)

print(model.predict([[4]])) #predicts 8









