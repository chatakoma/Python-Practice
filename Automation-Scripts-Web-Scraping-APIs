#Automation Scripts
#here's things that can be automated: renaming hundreds of files, moving backups,
#sending emails, cleaning folders, scheduling scripts
import os

folder = "C:/Users/Aicha/Desktop/files"

for i, filename in enumerate(os.listdir(folder)):
    old = os.path.join(folder, filename)
    new = os.path.join(folder, f"file_{i}.txt")
    os.rename(old, new)
 
#Web Scraping ==> used for extracting any data from the web!
